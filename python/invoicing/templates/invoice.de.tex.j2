\usepackage[ngerman]{babel}
\usepackage{ragged2e}%für Rausatz mit \RaggedRight
\usepackage{blindtext,mwe}%für Demo
\usepackage{fontspec}
\usepackage{fontawesome5}
\setmainfont{Roboto}

\usepackage[table]{xcolor}

%definieren von \grqq und \glqq ( „ bzw. “)
\renewcommand*{\glqq}{\quotedblbase}
\renewcommand*{\grqq}{\textquotedblleft}

\setkomavar{date}{ << invoice.issue_date >> }
\setkomavar{myref}{ << invoice.number >> }
\setkomavar{yourref}{ << invoice.po_number>> }
\setkomavar{customer}{ << buyer.customer_number >> }
\setkomavar{subject}{Rechnung << invoice.number >> }

\begin{document}
	%\RaggedRight %Rausatz? Sonst Blocksatz!
	\begin{letter}{ << buyer.name | latex >> \\
			- << buyer.contact.person_name | latex >> - \\
			<< buyer.street | latex >> \\
			<< buyer.zip >> << buyer.city | latex >> }
		
		\opening{Sehr geehrte Damen und Herren,}
		
		Gemäß Vereinbarung berechnen wir die nachfolgend aufgeführten Leistungen:
        
        \begingroup
            \small
            \begin{tabular}{|c|c|p{7.0cm}|c|r|r|r|r|}
                \hline
                \rowcolor{gray!15}
                \textbf{Pos.} & \textbf{ID} & \textbf{Description} & \textbf{Price} & \textbf{Unit} & \textbf{Cnt.} & \textbf{Tax} & \textbf{Netto} \\
                \hline
                <% for line in lines %>
                << loop.index >> & << line.assigned_id | latex >> & << line.name | latex >> \par \scriptsize \textit{ << line.description | latex >> } & << line.unit_price | eur >> & << line.unit_code >> & << line.quantity >> & << line.tax.rate >> & << (line.quantity * line.unit_price) | eur >> \\
                \hline
                <% endfor %>
            \end{tabular}

            \vspace{0.5em}

            \begin{tabular}{p{9cm} p{4cm} r}
            &    \textbf{Zwischensumme (netto)} & << net_total >>\,€ \\
            &    Umsatzsteuer (<< vat_rate_percent >>\,\%) & << vat_amount >>\,€ \\
            &    \textbf{Gesamtbetrag} & \textbf{<< gross_total >>\,€} \\
            \end{tabular}
        
        \endgroup

        Zahlbar bis zum << due_date >> ohne Abzüge.
        <% if payment.discount %>
        Skonto: << payment.discount.percent >>\% innerhalb von << payment.discount.days >> Tagen ab Rechnungsdatum.
        <% endif %>
        Bitte geben Sie bei der Überweisung die Rechnungsnummer als Verwendungszweck an.
        Wir danken für die gute Zusammenarbeit.
		\closing{Mit freundlichen Grüßen}
		
	\end{letter}

\end{document}